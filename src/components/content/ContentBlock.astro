---
import { getEntrySlug, readingTime } from '@/lib/content';
import type { CollectionEntry } from 'astro:content';
import ContentMeta from '@/components/content/ContentMeta.astro';
import ReadmoreLink from '@/components/content/ReadmoreLink.astro';

interface Props {
  entry: CollectionEntry<'writing'>;
}

const { entry } = Astro.props;
const href = `/writing/${getEntrySlug(entry)}`;
const minutes = readingTime(entry.body);
const excerpt =
  entry.data.description ??
  entry
    .body!.replace(/^---[\s\S]*?---/, '')
    .replace(/```[\s\S]*?```/g, '')
    .replace(/!\[[^\]]*\]\([^)]*\)/g, '')
    .replace(/\[[^\]]+\]\([^)]*\)/g, '$1')
    .replace(/[#>*_`~-]/g, '')
    .replace(/\s+/g, ' ')
    .trim()
    .slice(0, 180);
---

<article class="py-6">
  <ContentMeta date={entry.data.date} minutes={minutes} />
  <h2
    class="mt-4 font-sans text-2xl font-extrabold leading-snug text-balance sm:text-3xl"
  >
    <a href={href} class="no-underline transition-colors">{entry.data.title}</a>
  </h2>
  {excerpt && <p class="mt-4 max-w-3xl text-lg leading-relaxed text-muted">{excerpt}</p>}
  <ReadmoreLink href={href}>read more</ReadmoreLink>
</article>
