---
import { slugify } from '@/lib/content';

interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

{
  tags.length > 0 && (
    <div class="article-topics">
      <h2 class="font-mono">
        <span class="accent-marker">&gt;</span> topics
      </h2>
      <ul>
        {tags.map((tag, index) => (
          <li>
            {index > 0 && <span class="topic-separator">/</span>}
            <a href={`/topics/${slugify(tag)}`}>{tag}</a>
          </li>
        ))}
      </ul>
    </div>
  )
}

<style>
  .article-topics {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem;
    font-size: 0.875rem;
  }

  h2 {
    margin: 0;
    font-size: inherit;
    font-weight: 700;
  }

  ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  li {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  a {
    text-decoration: none;
  }

  .topic-separator {
    color: color-mix(in srgb, var(--color-accent) 30%, transparent);
  }
</style>
