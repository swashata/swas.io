---
interface Topic {
  slug: string;
  label: string;
  count?: number;
}

interface Props {
  topics: Topic[];
}

const { topics } = Astro.props;
---

<section class="site-container py-10">
  <div class="rule mb-8"></div>
  <h2 class="mb-6 text-xl font-bold"><span class="accent-marker">&gt;</span> topics</h2>
  <ul class="flex flex-wrap gap-x-4 gap-y-3 text-lg">
    {
      topics.map((topic, index) => (
        <li>
          <a href={`/topics/${topic.slug}`} class="no-underline">
            {topic.label}
          </a>
          {topic.count && <span class="ml-1 text-sm text-muted">({topic.count})</span>}
          {index < topics.length - 1 && <span class="ml-4 accent-marker">/</span>}
        </li>
      ))
    }
  </ul>
</section>
