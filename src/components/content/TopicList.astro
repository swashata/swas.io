---
import SectionTitle from '@/components/content/SectionTitle.astro';

interface Topic {
  slug: string;
  label: string;
  count?: number;
}

interface Props {
  topics: Topic[];
  title?: string;
  basePath?: string;
}

const { topics, title = 'topics', basePath = '/topics' } = Astro.props;
---

<SectionTitle>{title}</SectionTitle>
<ul class="flex flex-wrap gap-x-4 gap-y-3 pt-6 text-lg">
  {
    topics.map((topic, index) => (
      <li>
        <a href={`${basePath}/${topic.slug}`} class="no-underline">
          {topic.label}
        </a>
        {topic.count && <span class="ml-1 text-sm text-muted">({topic.count})</span>}
        {index < topics.length - 1 && <span class="ml-4 accent-marker">/</span>}
      </li>
    ))
  }
</ul>
