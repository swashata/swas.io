---
import type { LucideIcon } from 'lucide-react';

interface Props {
  href: string;
  command: string;
  description: string;
  icon: LucideIcon;
  class?: string;
}

const { href, command, description, icon: Icon, class: className } = Astro.props;
---

<a
  href={href}
  class:list={[
    'group relative isolate min-h-56 overflow-hidden border border-border px-6 py-7 no-underline transition-colors hover:border-accent sm:min-h-64 sm:px-8 sm:py-9',
    className,
  ]}
>
  <Icon
    aria-hidden="true"
    size={176}
    strokeWidth={1}
    className="pointer-events-none absolute -bottom-8 -right-8 -z-10 text-foreground opacity-10 transition-transform duration-300 group-hover:scale-105"
  />
  <h3 class="font-mono text-2xl font-bold leading-tight sm:text-3xl">
    <span class="accent-marker">/</span>{command}
  </h3>
  <p class="mt-8 mb-10 max-w-sm text-lg leading-relaxed text-muted">{description}</p>
</a>
