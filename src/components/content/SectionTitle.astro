---
interface Props {
  muted?: boolean;
  as?: 'h1' | 'h2' | 'h3' | 'h4' | 'h5' | 'h6';
  animated?: boolean;
}

const { muted = false, as = 'h2', animated = true } = Astro.props;
const Tag = as;
---

<Tag class:list={['pb-4 font-bold font-mono', muted ? 'text-sm text-muted' : 'text-xl']}>
  <span class="accent-marker mr-1">$</span>
  <slot />
  {animated ? <span class="animate-ping text-accent font-bold">_</span> : null}
</Tag>
