---
import { site } from '@/lib/content';
import type { ImageMetadata } from 'astro';

interface Props {
  title?: string;
  absoluteTitle?: string;
  description?: string;
  image?: string | ImageMetadata;
  type?: 'website' | 'article';
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
  section?: string;
  jsonLd?: Record<string, unknown>;
  noindex?: boolean;
}

const {
  title,
  absoluteTitle,
  description = site.description,
  image,
  type = 'website',
  publishedTime,
  modifiedTime,
  tags = [],
  section,
  jsonLd,
  noindex = false,
} = Astro.props;
const pageTitle = absoluteTitle ?? (title ? `${title} | ${site.title}` : site.title);
const metaDescription = description?.trim() || site.description;
const canonical = new URL(Astro.url.pathname, site.url).toString();
const imageUrl = image
  ? new URL(typeof image === 'string' ? image : image.src, site.url).toString()
  : undefined;
const imageMetadata = image && typeof image !== 'string' ? image : undefined;
const mimeType = imageMetadata
  ? `image/${imageMetadata.format === 'jpg' ? 'jpeg' : imageMetadata.format}`
  : undefined;
const robots = noindex
  ? 'noindex, follow'
  : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1';
const serializedJsonLd = jsonLd
  ? JSON.stringify(jsonLd).replace(/</g, '\\u003c')
  : undefined;
const siteJsonLd =
  Astro.url.pathname === '/'
    ? JSON.stringify({
        '@context': 'https://schema.org',
        '@graph': [
          {
            '@type': 'Person',
            '@id': `${site.url}/#person`,
            name: site.author,
            alternateName: site.alternateName,
            url: site.authorUrl,
            sameAs: site.socialLinks,
          },
          {
            '@type': 'WebSite',
            '@id': `${site.url}/#website`,
            url: site.url,
            name: site.name,
            alternateName: site.alternateName,
            description: site.description,
            inLanguage: site.language,
            publisher: { '@id': `${site.url}/#person` },
          },
        ],
      }).replace(/</g, '\\u003c')
    : undefined;
---

<title>{pageTitle}</title>
<meta name="description" content={metaDescription} />
<meta name="author" content={site.author} />
<meta name="robots" content={robots} />
<link rel="canonical" href={canonical} />
<link rel="author" href={site.authorUrl} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={metaDescription} />
<meta property="og:type" content={type} />
<meta property="og:url" content={canonical} />
<meta property="og:site_name" content={site.name} />
<meta property="og:locale" content={site.locale} />
{imageUrl && <meta property="og:image" content={imageUrl} />}
{imageUrl && <meta property="og:image:alt" content={pageTitle} />}
{imageMetadata && <meta property="og:image:width" content={imageMetadata.width} />}
{imageMetadata && <meta property="og:image:height" content={imageMetadata.height} />}
{mimeType && <meta property="og:image:type" content={mimeType} />}
{
  type === 'article' && publishedTime && (
    <meta property="article:published_time" content={publishedTime.toISOString()} />
  )
}
{
  type === 'article' && modifiedTime && (
    <meta property="article:modified_time" content={modifiedTime.toISOString()} />
  )
}
{type === 'article' && section && <meta property="article:section" content={section} />}
{type === 'article' && tags.map((tag) => <meta property="article:tag" content={tag} />)}
{type === 'article' && <meta property="article:author" content={site.authorUrl} />}
<meta name="twitter:card" content={imageUrl ? 'summary_large_image' : 'summary'} />
<meta name="twitter:site" content={site.twitterHandle} />
<meta name="twitter:creator" content={site.twitterHandle} />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={metaDescription} />
{imageUrl && <meta name="twitter:image" content={imageUrl} />}
{imageUrl && <meta name="twitter:image:alt" content={pageTitle} />}
{siteJsonLd && <script type="application/ld+json" set:html={siteJsonLd} />}
{serializedJsonLd && <script type="application/ld+json" set:html={serializedJsonLd} />}
