---
import Logo from '@/components/site/Logo.astro';

const nav = [
  { href: '/writing', label: 'writing' },
  // @todo Add project back when I have modified/polished those.
  // { href: '/projects', label: 'projects' },
  { href: '/about', label: 'about' },
  { href: '/now', label: 'now' },
];

const current = Astro.url.pathname;
---

<header class="site-container py-4 sm:pt-6">
  <div class="flex items-center justify-between gap-6">
    <Logo />
    <nav aria-label="Primary navigation">
      <ul
        class="flex flex-wrap items-center justify-end gap-x-4 gap-y-2 text-sm sm:gap-x-9 sm:text-xl font-mono"
      >
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={current.startsWith(item.href) ? 'page' : undefined}
                class="no-underline transition-colors aria-[current=page]:text-accent"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
  <div class="rule mt-4 sm:mt-6"></div>
</header>
