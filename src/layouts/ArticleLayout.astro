---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArticleEnhancements from '@/components/content/ArticleEnhancements.astro';
import ArticleToc from '@/components/content/ArticleToc.astro';
import ArticleTopics from '@/components/content/ArticleTopics.astro';
import ShareButton from '@/components/content/ShareButton.astro';
import { formatDate, readingTime, site, slugify } from '@/lib/content';

interface Props {
  title: string;
  description?: string;
  date: Date;
  category: string;
  tags?: string[];
  image?: ImageMetadata;
  updated?: Date;
  draft?: boolean;
  body?: string;
  headings?: Array<{ depth: number; slug: string; text: string }>;
}

const {
  title,
  description,
  date,
  category,
  tags = [],
  image,
  updated,
  draft = false,
  body = '',
  headings = [],
} = Astro.props;
const minutes = readingTime(body);
const shareUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://swas.io').toString();
const categoryHref = `/categories/${slugify(category)}`;
const tocHeadings = headings.filter((heading) => heading.depth > 1 && heading.depth < 4);
const imageUrl = image
  ? new URL(image.src, Astro.site ?? 'https://swas.io').toString()
  : undefined;
const metaDescription = description?.trim() || site.description;
---

<BaseLayout
  title={title}
  description={metaDescription}
  image={image}
  type="article"
  publishedTime={date}
  modifiedTime={updated ?? date}
  tags={tags}
  section={category}
  jsonLd={{
    '@context': 'https://schema.org',
    '@graph': [
      {
        '@type': 'BlogPosting',
        '@id': `${shareUrl}#article`,
        headline: title,
        description: metaDescription,
        datePublished: date.toISOString(),
        dateModified: (updated ?? date).toISOString(),
        mainEntityOfPage: shareUrl,
        url: shareUrl,
        articleSection: category,
        keywords: tags,
        author: {
          '@type': 'Person',
          '@id': `${site.url}/#person`,
          name: site.author,
          url: site.authorUrl,
          sameAs: site.socialLinks,
        },
        publisher: {
          '@type': 'Person',
          '@id': `${site.url}/#person`,
          name: site.author,
          url: site.authorUrl,
        },
        isPartOf: {
          '@type': 'WebSite',
          '@id': `${site.url}/#website`,
          name: site.name,
          url: site.url,
        },
        ...(imageUrl ? { image: [imageUrl] } : {}),
      },
      {
        '@type': 'BreadcrumbList',
        '@id': `${shareUrl}#breadcrumb`,
        itemListElement: [
          {
            '@type': 'ListItem',
            position: 1,
            name: 'Home',
            item: `${site.url}/`,
          },
          {
            '@type': 'ListItem',
            position: 2,
            name: 'Writing',
            item: `${site.url}/writing/`,
          },
          {
            '@type': 'ListItem',
            position: 3,
            name: title,
            item: shareUrl,
          },
        ],
      },
    ],
  }}
  hasToc={tocHeadings.length > 0}
>
  <article class="site-container py-8 pb-28 sm:py-12 lg:pb-12">
    <header>
      {
        draft && (
          <p class="mb-6 inline-flex border-y border-border py-2 font-mono text-sm font-bold text-accent">
            Draft preview
          </p>
        )
      }
      <div class="mb-7 flex items-start gap-4 font-mono text-sm sm:text-base">
        <p class="flex flex-wrap items-baseline gap-x-2 gap-y-1 text-muted">
          <span>
            <time datetime={date.toISOString()}>{formatDate(date)}</time>
            <span class="mx-1 text-foreground/50">under</span>
            <a
              href={categoryHref}
              class="font-medium text-foreground underline decoration-border underline-offset-4 transition-colors hover:decoration-accent"
            >
              {category}
            </a>
          </span>
          <span class="text-xs text-muted/75 sm:text-sm">({minutes} min read)</span>
        </p>
      </div>
      <h1 class="display-type max-w-5xl text-5xl leading-tight text-balance sm:text-6xl">
        {title}
      </h1>
      {
        description && (
          <p class="mt-10 max-w-5xl text-xl leading-relaxed sm:text-2xl font-mono">
            {description}
          </p>
        )
      }
    </header>

    <div
      class="mt-12 grid gap-12 lg:grid-cols-[minmax(0,65ch)_19rem] lg:items-start xl:grid-cols-[minmax(0,65ch)_21rem]"
    >
      <div class="min-w-0 max-w-prose">
        <div class="prose prose-editorial max-w-prose" data-article-prose>
          <slot />
        </div>

        <footer class="mt-12 border-t border-border pt-8">
          <span class="text-muted text-sm font-bold mr-5">Enjoyed this article?</span>
          <ShareButton title={title} url={shareUrl} />
          <div class="mt-8">
            <ArticleTopics tags={tags} />
          </div>
        </footer>

        <a href="/writing" class="mt-12 inline-block no-underline"
          ><span class="accent-marker">&lt;-</span> back to writing</a
        >
      </div>

      {
        tocHeadings.length > 0 && (
          <ArticleToc headings={tocHeadings} shareTitle={title} shareUrl={shareUrl} />
        )
      }
    </div>

    <ArticleEnhancements />
  </article>
</BaseLayout>
