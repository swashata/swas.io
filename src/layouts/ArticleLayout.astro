---
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ShareButton from '@/components/islands/ShareButton';
import { formatDate, readingTime, slugify } from '@/lib/content';

interface Props {
  title: string;
  description?: string;
  date: Date;
  category: string;
  tags?: string[];
  image?: ImageMetadata;
  body?: string;
}

const { title, description, date, category, tags = [], image, body = '' } = Astro.props;
const minutes = readingTime(body);
const shareUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://swas.io').toString();
const categoryHref = `/categories/${slugify(category)}`;
---

<BaseLayout title={title} description={description} type="article">
  <article class="site-container py-16 sm:py-24">
    <header class="grid gap-12 lg:grid-cols-[minmax(0,1fr)_12rem] lg:items-end">
      <div>
        <p class="mb-8 flex flex-wrap gap-x-4 gap-y-2 text-sm text-muted sm:text-base">
          <time datetime={date.toISOString()}>{formatDate(date)}</time>
          <span class="accent-marker">/</span>
          <span>{minutes} min read</span>
          <span class="accent-marker">/</span>
          <a href={categoryHref} class="no-underline">{category}</a>
        </p>
        <h1 class="display-type max-w-5xl text-5xl sm:text-7xl lg:text-8xl">{title}</h1>
        {
          description && (
            <p class="mt-8 max-w-4xl text-xl leading-relaxed sm:text-2xl">
              {description}
            </p>
          )
        }
      </div>
      <div class="flex lg:justify-end">
        <ShareButton client:load title={title} url={shareUrl} />
      </div>
    </header>

    {
      image && (
        <Image
          src={image}
          alt=""
          widths={[640, 960, 1280]}
          sizes="(min-width: 1024px) 960px, calc(100vw - 2rem)"
          class="mt-12 w-full max-w-4xl border border-border"
          loading="lazy"
        />
      )
    }

    <div class="mt-12 grid gap-12 lg:grid-cols-[minmax(0,46rem)_12rem]">
      <div class="prose prose-editorial">
        <slot />
      </div>
      {
        tags.length > 0 && (
          <aside class="pt-2 text-sm lg:pt-0">
            <h2 class="mb-4 font-bold">
              <span class="accent-marker">&gt;</span> topics
            </h2>
            <ul class="grid gap-2">
              {tags.map((tag) => (
                <li>
                  <a
                    href={`/topics/${tag
                      .toLowerCase()
                      .replace(/['"]/g, '')
                      .replace(/[^a-z0-9]+/g, '-')
                      .replace(/^-|-$/g, '')}`}
                    class="no-underline"
                  >
                    {tag}
                  </a>
                </li>
              ))}
            </ul>
          </aside>
        )
      }
    </div>
    <a href="/writing" class="mt-12 inline-block no-underline"
      ><span class="accent-marker">&lt;-</span> back to writing</a
    >
  </article>
</BaseLayout>
