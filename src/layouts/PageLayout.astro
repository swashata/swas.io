---
import ArticleEnhancements from '@/components/content/ArticleEnhancements.astro';
import ArticleToc from '@/components/content/ArticleToc.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  description?: string;
  image?: ImageMetadata;
  headings?: Array<{ depth: number; slug: string; text: string }>;
}

const { title, description, image, headings = [] } = Astro.props;
const tocHeadings = headings.filter((heading) => heading.depth > 1 && heading.depth < 4);
const shareUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://swas.io').toString();
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  hasToc={tocHeadings.length > 0}
>
  <section class="site-container py-8 pb-28 sm:py-12 lg:pb-12">
    <header>
      <h1 class="display-type max-w-5xl text-5xl leading-tight text-balance sm:text-6xl">
        {title}
      </h1>
      {
        description && (
          <p class="mt-10 max-w-5xl text-xl leading-relaxed sm:text-2xl font-mono">
            {description}
          </p>
        )
      }
    </header>

    <div
      class="mt-12 grid gap-12 lg:grid-cols-[minmax(0,65ch)_19rem] lg:items-start xl:grid-cols-[minmax(0,65ch)_21rem]"
    >
      <div class="min-w-0 max-w-prose">
        <div class="prose prose-editorial max-w-prose" data-article-prose>
          <slot />
        </div>
      </div>

      {
        tocHeadings.length > 0 && (
          <ArticleToc headings={tocHeadings} shareTitle={title} shareUrl={shareUrl} />
        )
      }
    </div>

    <ArticleEnhancements />
  </section>
</BaseLayout>
