---
import ContentArchive from '@/components/content/ContentArchive.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  filterVisibleWritingEntries,
  getAllTopics,
  slugify,
  sortByDateDesc,
} from '@/lib/content';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const entries = sortByDateDesc(
    filterVisibleWritingEntries(await getCollection('writing')),
  );
  const topics = getAllTopics(entries);

  return topics.map((topic) => ({
    params: { slug: topic.slug },
    props: {
      topic,
      entries: entries.filter((entry) =>
        entry.data.tags.some((tag) => slugify(tag) === topic.slug),
      ),
    },
  }));
}

const { topic, entries } = Astro.props;
---

<BaseLayout
  title={topic.label}
  description={`Writing tagged ${topic.label}.`}
  image={`/featured-images/topics/${topic.slug}.png`}
>
  <ContentArchive entries={entries} title={topic.label} />
</BaseLayout>
