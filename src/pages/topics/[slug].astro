---
import ContentList from '@/components/content/ContentList.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getAllTopics, slugify, sortByDateDesc } from '@/lib/content';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const entries = sortByDateDesc(
    (await getCollection('writing')).filter((entry) => !entry.data.draft),
  );
  const topics = getAllTopics(entries);

  return topics.map((topic) => ({
    params: { slug: topic.slug },
    props: {
      topic,
      entries: entries.filter((entry) =>
        entry.data.tags.some((tag) => slugify(tag) === topic.slug),
      ),
    },
  }));
}

const { topic, entries } = Astro.props;
---

<BaseLayout title={topic.label} description={`Writing tagged ${topic.label}.`}>
  <section class="site-container py-16 sm:py-24">
    <p class="mb-6 text-sm text-muted"><span class="accent-marker">&gt;</span> topic</p>
    <h1 class="display-type text-6xl sm:text-8xl">{topic.label}</h1>
  </section>
  <ContentList entries={entries} />
</BaseLayout>
