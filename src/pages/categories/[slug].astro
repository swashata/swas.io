---
import ContentArchive from '@/components/content/ContentArchive.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  filterVisibleWritingEntries,
  getAllCategories,
  slugify,
  sortByDateDesc,
} from '@/lib/content';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const entries = sortByDateDesc(
    filterVisibleWritingEntries(await getCollection('writing')),
  );
  const categories = getAllCategories(entries);

  return categories.map((category) => ({
    params: { slug: category.slug },
    props: {
      category,
      entries: entries.filter((entry) => slugify(entry.data.category) === category.slug),
    },
  }));
}

const { category, entries } = Astro.props;
---

<BaseLayout title={category.label} description={category.description}>
  <ContentArchive
    entries={entries}
    title={category.label}
    description={category.description}
  />
</BaseLayout>
