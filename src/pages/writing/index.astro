---
import ContentArchive from '@/components/content/ContentArchive.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { filterVisibleWritingEntries, sortByDateDesc } from '@/lib/content';
import { getCollection } from 'astro:content';

const entries = sortByDateDesc(
  filterVisibleWritingEntries(await getCollection('writing')),
);
---

<BaseLayout
  title="All Articles written by swas.io"
  description="Notes on engineering, systems, developer tooling, product work, and practical AI."
>
  <ContentArchive
    entries={entries}
    title="writing"
    description="Long-form notes and working thoughts from the craft of building software."
  />
</BaseLayout>
