---
import ContentArchive from '@/components/content/ContentArchive.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { sortByDateDesc } from '@/lib/content';
import { getCollection } from 'astro:content';

const entries = sortByDateDesc(
  (await getCollection('writing')).filter((entry) => !entry.data.draft),
);
---

<BaseLayout
  title="Writing"
  description="Notes on engineering, systems, developer tooling, product work, and practical AI."
>
  <ContentArchive
    entries={entries}
    label="archive"
    title="Writing"
    description="Long-form notes and working thoughts from the craft of building software."
  />
</BaseLayout>
