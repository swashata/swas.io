---
import featuredImageHome from '@/assets/featured-image/featured-image-home.png';
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Not Found"
  description="This page does not exist."
  image={featuredImageHome}
  noindex
>
  <section class="site-container py-24">
    <p class="mb-6 text-sm text-muted"><span class="accent-marker">&gt;</span> 404</p>
    <h1 class="display-type text-6xl sm:text-8xl">Not found</h1>
    <p class="mt-8 max-w-2xl text-xl">This page is not here anymore.</p>
    <a href="/" class="mt-10 inline-block no-underline"
      ><span class="accent-marker">&lt;-</span> back home</a
    >
  </section>
</BaseLayout>
